{
  "name": "alinea",
  "version": "0.0.0",
  "description": "Headless git-based CMS",
  "repository": "github:alineacms/alinea",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "imports": {
    "#/*": "./src/*",
    "#test/*": "./test/*"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./dist/index.js",
    "./css": "./dist/index.css",
    "./next": {
      "edge-light": "./dist/next.edge.js",
      "require": "./dist/next.cjs",
      "default": "./dist/next.js"
    },
    "./*.cjs": "./dist/*.cjs",
    "./*": "./dist/*.js",
    "./core/media/CreatePreview": {
      "edge-light": "./dist/core/media/CreatePreview.js",
      "worker": "./dist/core/media/CreatePreview.js",
      "browser": "./dist/core/media/CreatePreview.browser.js",
      "default": "./dist/core/media/CreatePreview.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*"
      ]
    }
  },
  "bin": "./dist/cli.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsgo --noEmit false --declaration --emitDeclarationOnly && bun build.ts",
    "bump": "bun bump.js",
    "cycles:browser": "CHECK_CYCLES=browser bun build.ts && bunx --bun madge --warning --circular dist/index.js dist/ui.js dist/dashboard/App.js",
    "cycles:server": "CHECK_CYCLES=server bun build.ts && bunx --bun madge --warning --circular dist/index.js",
    "dev": "run-p dev:run",
    "dev:check": "tsgo -w",
    "dev:run": "bun build.ts --watch -- node dev.js --dir apps/dev -- bun run --cwd apps/dev dev",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --ignore-path .gitignore .",
    "lint:fix": "oxlint --fix --ignore-path .gitignore .",
    "prepublishOnly": "bun run build",
    "stories": "ladle serve",
    "tag": "bun tag.js",
    "trace": "tsc --diagnostics --generateTrace private/trace && analyze-trace private/trace & speedscope private/trace/trace.json",
    "type": "tsgo --diagnostics",
    "web": "run-p dev:check web:run",
    "web:run": "bun build.ts --watch -- node dev.js -- bun run --cwd apps/web dev"
  },
  "resolutions": {
    "lib0": "0.2.88",
    "yjs": "13.6.11"
  },
  "dependencies": {
    "@alinea/components": "^0.0.49",
    "@alinea/iso": "^0.3.3",
    "esbuild": "^0.25.4",
    "react-aria-components": "^1.16.0"
  },
  "devDependencies": {
    "@alinea/styler": "^1.0.3",
    "@alinea/suite": "^0.6.3",
    "@badgateway/oauth2-client": "^3.2.0",
    "@esbx/reporter": "^0.0.20",
    "@esbx/workspaces": "^0.0.20",
    "@happy-dom/global-registrator": "^20.8.3",
    "@ladle/react": "^4.1.2",
    "@tiptap/core": "^2.1.16",
    "@tiptap/extension-blockquote": "^2.1.16",
    "@tiptap/extension-bold": "^2.1.16",
    "@tiptap/extension-bullet-list": "^2.1.16",
    "@tiptap/extension-document": "^2.1.16",
    "@tiptap/extension-dropcursor": "^2.1.16",
    "@tiptap/extension-floating-menu": "^2.1.16",
    "@tiptap/extension-gapcursor": "^2.1.16",
    "@tiptap/extension-hard-break": "^2.1.16",
    "@tiptap/extension-heading": "^2.1.16",
    "@tiptap/extension-highlight": "^3.20.1",
    "@tiptap/extension-history": "^2.1.16",
    "@tiptap/extension-horizontal-rule": "^2.1.16",
    "@tiptap/extension-italic": "^2.1.16",
    "@tiptap/extension-list-item": "^2.1.16",
    "@tiptap/extension-ordered-list": "^2.1.16",
    "@tiptap/extension-paragraph": "^2.1.16",
    "@tiptap/extension-strike": "^2.1.16",
    "@tiptap/extension-subscript": "^2.2.4",
    "@tiptap/extension-superscript": "^2.2.4",
    "@tiptap/extension-table": "^2.1.16",
    "@tiptap/extension-table-cell": "^2.1.16",
    "@tiptap/extension-table-header": "^2.1.16",
    "@tiptap/extension-table-row": "^2.1.16",
    "@tiptap/extension-text": "^2.1.16",
    "@tiptap/extension-text-align": "^2.1.16",
    "@tiptap/pm": "^2.1.16",
    "@tiptap/react": "^2.1.16",
    "@types/bun": "^1.3.12",
    "@types/escape-html": "^1.0.2",
    "@types/fs-extra": "^11.0.1",
    "@types/glob": "^7.1.4",
    "@types/node": "^25.6.0",
    "@types/react": "^18.2.13",
    "@types/react-dom": "^18.2.6",
    "@typescript/analyze-trace": "^0.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260325.1",
    "@vitejs/plugin-react": "^6.0.1",
    "cito": "^0.3.3",
    "color2k": "^1.2.4",
    "compare-versions": "^4.1.3",
    "cookie-es": "^1.2.2",
    "escape-html": "^1.0.3",
    "fake-indexeddb": "^6.0.0",
    "get-tsconfig": "^4.6.0",
    "glob": "^7.2.0",
    "htmlparser2": "^9.1.0",
    "jotai": "^2.4.2",
    "jotai-location": "^0.6.2",
    "knip": "^6.4.1",
    "lib0": "^0.2.88",
    "lolight": "^1.4.1",
    "madge": "^6.1.0",
    "minisearch": "^7.1.2",
    "next": "^16.1.6",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.39.0",
    "oxlint": "^1.54.0",
    "p-debounce": "^4.0.0",
    "p-lazy": "^4.0.0",
    "p-limit": "^4.0.0",
    "postcss-modules": "^6.0.0",
    "postcss-pxtorem": "^6.0.0",
    "pretty-bytes": "^6.0.0",
    "pretty-ms": "^8.0.0",
    "rado": "^1.0.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "regexparam": "^2.0.1",
    "sade": "^1.8.1",
    "sass": "^1.63.4",
    "sass-embedded": "^1.83.4",
    "smartcrop": "^2.0.5",
    "speedscope": "^1.14.0",
    "symlink-dir": "^6.0.5",
    "thumbhash": "^0.1.1",
    "typescript": "^6.0.2",
    "typescript-plugin-css-modules": "^5.2.0",
    "vite": "^8.0.0",
    "vite-plus": "^0.1.16",
    "yjs": "^13.6.11",
    "yjs-src": "npm:yjs@13.6.11"
  }
}
