{
  "compilerOptions": {
    "noEmit": true,
    "outDir": "dist",
    "rootDir": "src",
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "preserveWatchOutput": true,
    "moduleDetection": "force",
    "incremental": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [{ "name": "typescript-plugin-css-modules" }],
    "lib": ["dom.iterable", "dom", "webworker", "es2025"],
    "paths": {
      // This is only required for bun, which doesn't seem to support the
      // imports declared in package.json
      "#/*": ["./src/*"],
      "#test/*": ["./test/*"],
      // Required for bun to resolve this package to source during runtime
      "alinea": ["./src/index.ts"],
      "alinea/*": ["./src/*"]
    }
  },
  "exclude": ["apps", "v1"]
}
